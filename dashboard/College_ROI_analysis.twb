            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone h='26377' id='6' name='Highest Earnings' w='49473' x='527' y='44495'>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone h='26377' id='7' name='Earnings Growth' w='49473' x='50000' y='44495'>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='15889' id='8' type-v2='text' w='98946' x='527' y='917'>
            <formatted-text>
              <run fontcolor='#000000' fontsize='20'>College Major ROI Analysis</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='15'>Analysis of student debt, earnings, earnings growth, and return on investment across U.S. college majors.</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='28211' id='9' type-v2='text' w='98946' x='527' y='70872'>
            <formatted-text>
              <run fontcolor='#000000' fontsize='12' underline='true'>Key Findings</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='12'>Applied Mathematics delivered the highest ROI, generating $5.49 in earnings for every $1 of student debt.</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='12'>Computer Engineering and Computer Science produced the highest 5-year earnings, both exceeding $110,000 annually.</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='12'>Pharmacy showed the strongest earnings growth, with salaries increasing by nearly $40,000 between Year 1 and Year 5.</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='12'>Technology-focused majors often appeared among the highest-debt programs, suggesting students may accept larger borrowing costs in exchange for stronger long-term earnings potential.</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='10'>Created by Katie Cheng</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='10'>Data Source: U.S. Department of Education College Scorecard</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
